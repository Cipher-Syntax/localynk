{
	"cli": {
		"version": ">= 16.26.0",
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"env": {
				"EXPO_PUBLIC_API_URL": "https://backend.my-friendly-local-guide.com",
				"EXPO_PUBLIC_GOOGLE_CLIENT_ID": "483220783523-5shfec08dbf87rp5qtve73ih7pg9sbub.apps.googleusercontent.com"
			}
		},
		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development"
		},
		"preview": {
			"extends": "base",
			"distribution": "internal",
			"android": {
				"buildType": "apk"
